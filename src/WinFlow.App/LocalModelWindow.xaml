<Window x:Class="WinFlow.App.LocalModelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinFlow — Offline Model"
        Width="480" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock x:Name="TitleLabel" FontWeight="SemiBold" Margin="0,0,0,6" />
        <TextBlock x:Name="DetailLabel" TextWrapping="Wrap" Margin="0,0,0,14"
                   Foreground="#9aa0a6" FontSize="12" />

        <ProgressBar x:Name="Progress" Height="18" Minimum="0" Maximum="100"
                     Visibility="Collapsed" Margin="0,0,0,6" />
        <TextBlock x:Name="StatusText" FontFamily="Consolas" FontSize="11"
                   TextWrapping="Wrap" Margin="0,0,0,14" Visibility="Collapsed" />

        <StackPanel x:Name="ButtonPanel" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,0,0,0">
            <Button x:Name="PrimaryButton" Content="Download" Padding="16,6"
                    IsDefault="True" Click="OnPrimary" />
            <Button Content="Close" Padding="16,6" Margin="8,0,0,0" IsCancel="True"
                    Click="OnClose" />
        </StackPanel>
    </StackPanel>
</Window>
